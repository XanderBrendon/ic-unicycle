// Real SNS governance init payload — Sneed-equivalent, installed in Normal mode.
//
// One dominant neuron (id = 32x 0x01) holds 100% of the voting power. The dev
// identity (nas6b-…) controls it with all permissions; the unicycle backend
// (a2cb4-…) is hotkeyed with SUBMIT_PROPOSAL(3)+VOTE(4) so proposals it submits
// through this neuron auto-adopt and execute immediately.
//
// `parameters` are copied verbatim from Sneed mainnet
// (get_nervous_system_parameters) EXCEPT two background timers that would call
// NNS canisters that are intentionally not deployed locally:
//   - automatically_advance_target_version: true  -> false  (no SNS-Wasm upgrade polling)
//   - maturity_modulation_disabled:         false -> true   (no NNS maturity-modulation call)
//
// Placeholder principal tokens (double-at-name-double-at) are substituted with
// the live local canister ids from .icp/cache/mappings/local.ids.json by
// devscripts/encode-sns-init.sh, which produces governance_init.bin (what
// icp.yaml actually installs). swap=hshru-… is Sneed's real swap id, an inert
// placeholder never called in Normal mode.
// The neuron's 32-byte id is what the backend stores as its proposal neuron and
// sends as `manage_neuron.subaccount`.
(record {
  mode = 1 : int32;
  root_canister_id = opt principal "@@sns_root@@";
  ledger_canister_id = opt principal "@@sns_ledger@@";
  swap_canister_id = opt principal "hshru-3iaaa-aaaaq-aaciq-cai";
  sns_initialization_parameters = "";
  genesis_timestamp_seconds = 1_700_000_000 : nat64;
  id_to_nervous_system_functions = vec {};
  proposals = vec {};
  in_flight_commands = vec {};
  metrics = null;
  maturity_modulation = null;
  is_finalizing_disburse_maturity = null;
  deployed_version = null;
  cached_upgrade_steps = null;
  latest_reward_event = null;
  pending_version = null;
  target_version = null;
  timers = null;
  upgrade_journal = null;
  sns_metadata = opt record {
    name = opt "Sneed";
    description = opt "A 'blank canvas' DAO designed to enable the community to innovate, Sneed offers an accessible, open platform for creative and technological exploration on the Internet Computer Protocol.\n";
    url = opt "https://4pk43-5qaaa-aaaag-qc44a-cai.icp0.io/";
    logo = null;
  };
  parameters = opt record {
    default_followees = opt record { followees = vec {} };
    max_dissolve_delay_seconds = opt (15_780_096 : nat64);
    max_dissolve_delay_bonus_percentage = opt (100 : nat64);
    max_followees_per_function = opt (15 : nat64);
    neuron_claimer_permissions = opt record {
      permissions = vec { 0:int32; 1:int32; 2:int32; 3:int32; 4:int32; 5:int32; 6:int32; 7:int32; 8:int32; 9:int32; 10:int32 }
    };
    neuron_minimum_stake_e8s = opt (1_000_000 : nat64);
    max_neuron_age_for_age_bonus = opt (31_557_600 : nat64);
    initial_voting_period_seconds = opt (345_600 : nat64);
    neuron_minimum_dissolve_delay_to_vote_seconds = opt (2_630_016 : nat64);
    reject_cost_e8s = opt (10_000_000 : nat64);
    max_proposals_to_keep_per_action = opt (100 : nat32);
    wait_for_quiet_deadline_increase_seconds = opt (86_400 : nat64);
    max_number_of_neurons = opt (200_000 : nat64);
    transaction_fee_e8s = opt (1_000 : nat64);
    max_number_of_proposals_with_ballots = opt (700 : nat64);
    max_age_bonus_percentage = opt (25 : nat64);
    neuron_grantable_permissions = opt record {
      permissions = vec { 0:int32; 1:int32; 2:int32; 3:int32; 4:int32; 5:int32; 6:int32; 7:int32; 8:int32; 9:int32; 10:int32 }
    };
    voting_rewards_parameters = opt record {
      round_duration_seconds = opt (31_536_000 : nat64);
      reward_rate_transition_duration_seconds = opt (0 : nat64);
      initial_reward_rate_basis_points = opt (0 : nat64);
      final_reward_rate_basis_points = opt (0 : nat64);
    };
    maturity_modulation_disabled = opt true;
    max_number_of_principals_per_neuron = opt (5 : nat64);
    automatically_advance_target_version = opt false;
    custom_proposal_criticality = null;
  };
  neurons = vec {
    record {
      "0101010101010101010101010101010101010101010101010101010101010101";
      record {
        id = opt record {
          id = blob "\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01\01"
        };
        permissions = vec {
          record {
            "principal" = opt principal "nas6b-kglsn-zvzrl-o4vro-775rf-ls5mb-bwknk-gqgfq-gi2pm-23xbm-gqe";
            permission_type = vec { 0:int32; 1:int32; 2:int32; 3:int32; 4:int32; 5:int32; 6:int32; 7:int32; 8:int32; 9:int32; 10:int32 }
          };
          record {
            "principal" = opt principal "@@unicycle_backend@@";
            permission_type = vec { 3:int32; 4:int32 }
          };
        };
        cached_neuron_stake_e8s = 100_000_000_000_000 : nat64;
        neuron_fees_e8s = 0 : nat64;
        created_timestamp_seconds = 1_700_000_000 : nat64;
        aging_since_timestamp_seconds = 1_700_000_000 : nat64;
        maturity_e8s_equivalent = 0 : nat64;
        voting_power_percentage_multiplier = 100 : nat64;
        dissolve_state = opt variant { DissolveDelaySeconds = 15_780_096 : nat64 };
        staked_maturity_e8s_equivalent = null;
        source_nns_neuron_id = null;
        auto_stake_maturity = null;
        vesting_period_seconds = null;
        disburse_maturity_in_progress = vec {};
        followees = vec {};
        topic_followees = null;
      }
    };
  };
})
